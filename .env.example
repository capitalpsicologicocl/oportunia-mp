# Supabase (mismo proyecto que usas en local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cifrado de API keys en DB (mínimo 32 caracteres; genera uno aleatorio)
ENCRYPTION_KEY=

# Sesión de login (opcional; si falta usa SUPABASE_SERVICE_ROLE_KEY)
SESSION_SECRET=

# Cron nocturno Vercel → /api/cron/ingest
CRON_SECRET=

# Anthropic (opcional si la key ya está en Ajustes/onboarding)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ChileCompra (opcional; el ticket normalmente vive en org_settings)
CHILECOMPRA_TICKET=
CHILECOMPRA_API2_BASE_URL=https://api2.mercadopublico.cl
